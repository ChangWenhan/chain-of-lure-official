VICTIM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
JUDGE_API_KEY=
JUDGE_BASE_URL=https://api.openai.com/v1

# Optional model names
ATTACKER_MODEL=deepseek-v3
